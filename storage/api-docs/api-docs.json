            },
            "post": {
                "tags": [
                    "Bookings"
                ],
                "summary": "Create a booking",
                "operationId": "370f7a442431caac3f3d940cee5cad2a",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "catamaran_id",
                                    "location_type",
                                    "charter_type",
                                    "duration",
                                    "charter_price"
                                ],
                                "properties": {
                                    "catamaran_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "catamaran_name": {
                                        "type": "string",
                                        "example": "Ocean Spirit"
                                    },
                                    "location_type": {
                                        "type": "string",
                                        "enum": [
                                            "dar_es_salaam",
                                            "zanzibar"
                                        ]
                                    },
                                    "charter_type": {
                                        "type": "string",
                                        "enum": [
                                            "half_day",
                                            "full_day",
                                            "live_onboard"
                                        ]
                                    },
                                    "duration": {
                                        "description": "Charter duration in hours",
                                        "type": "integer",
                                        "example": 4
                                    },
                                    "charter_price": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 500
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Booking created"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
